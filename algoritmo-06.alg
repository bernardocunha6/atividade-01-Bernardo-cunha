Algoritmo "algoritmo06"
//  
//  

Var
   nome, endereco, telefone : caractere

Inicio

   escreva("Digite o nome: ")
   leia(nome)

   escreva("Digite o endereco: ")
   leia(endereco)

   escreva("Digite o telefone: ")
   leia(telefone)

   escreval("")
   escreval("Nome: ", nome)
   escreval("Endereco: ", endereco)
   escreval("Telefone: ", telefone)

Fimalgoritmo
